# Haven product app — environment variables.
#
# Copy to .env.local for local dev. Vercel project settings hold the
# production values.

# ────────────────────────────────────────────────────────────────────
# Gigs Mobile Operator API
# ────────────────────────────────────────────────────────────────────
# Request from support@gigs.com. One key per Gigs project (test, prod).
# When unset, the app runs against the local mock fixtures in
# app/lib/gigs/mock.ts so the dashboard is fully usable for demos.
GIGS_API_KEY=
# The Gigs project ID. Used in every project-scoped path
# (/projects/${GIGS_PROJECT_ID}/...).
GIGS_PROJECT_ID=
# Optional override — defaults to https://api.gigs.com
# GIGS_BASE_URL=https://api.gigs.com

# Shared secret used to verify the HMAC signature on inbound webhook
# deliveries to /api/webhooks/gigs. Configured in the Gigs dashboard
# when setting up the webhook endpoint.
GIGS_WEBHOOK_SECRET=
# Header name Gigs uses to deliver the signature. Default models the
# Stripe convention — update once Gigs documents theirs.
# GIGS_WEBHOOK_SIG_HEADER=gigs-signature

# ────────────────────────────────────────────────────────────────────
# Postgres (shared with marketing-site waitlist for now)
# ────────────────────────────────────────────────────────────────────
# Auto-populated when you connect a Vercel/Neon Postgres store to this
# project in the Vercel dashboard. Locally, paste the same URL into
# .env.local from the marketing project.
POSTGRES_URL=

# ────────────────────────────────────────────────────────────────────
# Auth — sign-in cookies + /api/migrate gate
# ────────────────────────────────────────────────────────────────────
# Generate once: `openssl rand -hex 32` (min 16 chars).
# Rotating it invalidates every active session — so set it once and
# leave it alone.
AUTH_SECRET=
# Optional override — defaults to "Haven <hello@gethavenmobile.com>".
# Use a Resend-verified sender. For first-deploy testing without a
# verified domain, set to "Haven <onboarding@resend.dev>".
# AUTH_FROM_ADDRESS=

# ────────────────────────────────────────────────────────────────────
# Email — magic-link auth + weekly digest sends
# ────────────────────────────────────────────────────────────────────
# Get one at resend.com → API Keys. When unset, magic-link URLs are
# logged to the server console instead of emailed (handy for dev).
RESEND_API_KEY=

# ────────────────────────────────────────────────────────────────────
# Analytics
# ────────────────────────────────────────────────────────────────────
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
